# Import libraries
import pandas as pd
from sklearn.linear_model import LogisticRegression

# Create dataset
data = {
    'Hours': [1, 2, 3, 4, 5, 6],
    'Result': [0, 0, 0, 1, 1, 1]
}

df = pd.DataFrame(data)

# Input and Output
X = df[['Hours']]
y = df['Result']

# Model
model = LogisticRegression()

# Train model
model.fit(X, y)

# Prediction
prediction = model.predict([[3.5]])

print("Prediction for 3.5 hours:", prediction)
